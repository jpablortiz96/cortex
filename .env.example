# CORTEX — Environment Variables
# Copy this to .env and fill in your keys

# Required: Anthropic API key for agent LLM calls
ANTHROPIC_API_KEY=your-key-here

# Optional: Kraken API (for production trading)
# KRAKEN_API_KEY=
# KRAKEN_API_SECRET=

# Optional: PRISM/Strykr API for market signals
# PRISM_API_KEY=
